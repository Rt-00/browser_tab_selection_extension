{
  "manifest_version": 3,
  "name": "Tab Selector",
  "description": "Seletor de abas estilo VSCode com busca fuzzy",
  "version": "1.0",
  "permissions": ["tabs"],
  "commands": {
    "open-tab-switcher": {
      "suggested_key": {
        "default": "Ctrl+Q",
        "mac": "Command+Q"
      },
      "description": "Abrir seletor de abas"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Tab Selector (Ctrl+Q)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
